# Home Finder - Environment Variables Example

# Google Gemini API Key (Obtain from https://aistudio.google.com/)
GOOGLE_API_KEY=your_gemini_api_key_here

# Anthropic API Key (Obtain from https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key (Obtain from https://platform.openai.com/)
OPENAI_API_KEY=your_openai_api_key_here

# Moonshot AI (Kimi) API Key (Obtain from https://platform.moonshot.cn/)
MOONSHOT_API_KEY=your_moonshot_api_key_here

# Tavily API Key for the OSINT agent (Obtain from https://tavily.com/)
TAVILY_API_KEY=your_tavily_api_key_here

# Google Maps API Key for the Commuter agent (Obtain from https://console.cloud.google.com/)
# Needs 'Distance Matrix API' enabled
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Observability (LangSmith) ---
# Set to 'true' to enable tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT="HomeFinder"
LANGCHAIN_API_KEY=your_langsmith_api_key_here
